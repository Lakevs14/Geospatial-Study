<style>
  @import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;1,400&family=DM+Sans:wght@300;400;500&display=swap');

  *{box-sizing:border-box;margin:0;padding:0}
  :root{
    --nav-h:60px;
    --serif:'Lora',Georgia,serif;
    --sans:'DM Sans',sans-serif;
    --blue:#185FA5;
    --blue-light:#E6F1FB;
    --teal:#0F6E56;
    --teal-light:#E1F5EE;
    --text:#2C2C2A;
    --muted:#5F5E5A;
    --border:#D3D1C7;
    --bg:#F8F7F4;
    --white:#ffffff;
  }

  body{font-family:var(--sans);color:var(--text);background:var(--bg);font-size:16px;line-height:1.7}

  nav{
    position:sticky;top:0;z-index:100;
    background:var(--white);
    border-bottom:1px solid var(--border);
    height:var(--nav-h);
    display:flex;align-items:center;justify-content:space-between;
    padding:0 2rem;
  }
  .nav-brand{font-family:var(--serif);font-size:18px;font-weight:500;color:var(--blue);letter-spacing:-0.3px}
  .nav-links{display:flex;gap:2rem;list-style:none}
  .nav-links a{font-size:14px;color:var(--muted);text-decoration:none;transition:color .2s}
  .nav-links a:hover{color:var(--blue)}
  .nav-toggle{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px}
  .nav-toggle span{display:block;width:22px;height:1.5px;background:var(--text);transition:.3s}

  .hero{
    background:var(--white);
    border-bottom:1px solid var(--border);
    padding:5rem 2rem 4rem;
    text-align:center;
    max-width:860px;margin:0 auto;
  }
  .hero-tag{
    display:inline-block;
    font-size:11px;letter-spacing:1.5px;text-transform:uppercase;
    color:var(--teal);background:var(--teal-light);
    padding:4px 12px;border-radius:20px;margin-bottom:1.5rem;
    font-weight:500;
  }
  .hero h1{font-family:var(--serif);font-size:clamp(26px,4vw,42px);font-weight:400;line-height:1.25;color:var(--text);margin-bottom:1rem}
  .hero h1 em{color:var(--blue);font-style:italic}
  .hero-sub{font-size:16px;color:var(--muted);max-width:620px;margin:0 auto 2rem;line-height:1.8}
  .hero-meta{display:flex;flex-wrap:wrap;justify-content:center;gap:1.5rem;font-size:13px;color:var(--muted)}
  .hero-meta span{display:flex;align-items:center;gap:6px}
  .dot{width:6px;height:6px;border-radius:50%;background:var(--blue);display:inline-block}

  .section{padding:4rem 2rem;max-width:1100px;margin:0 auto}
  .section-label{font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(--blue);font-weight:500;margin-bottom:.75rem}
  .section h2{font-family:var(--serif);font-size:clamp(20px,3vw,30px);font-weight:400;margin-bottom:1.5rem;color:var(--text)}
  .section p{color:var(--muted);max-width:720px;margin-bottom:1rem;line-height:1.85}

  .divider{border:none;border-top:1px solid var(--border);margin:0}

  .stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-top:2rem}
  .stat-card{background:var(--white);border:0.5px solid var(--border);border-radius:12px;padding:1.25rem;text-align:center}
  .stat-val{font-family:var(--serif);font-size:32px;color:var(--blue);font-weight:400;line-height:1}
  .stat-label{font-size:12px;color:var(--muted);margin-top:6px;line-height:1.4}

  .findings-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;margin-top:2rem}
  .finding-card{background:var(--white);border:0.5px solid var(--border);border-radius:12px;padding:1.5rem}
  .finding-county{font-size:11px;letter-spacing:1.2px;text-transform:uppercase;font-weight:500;margin-bottom:.5rem}
  .finding-card.sj .finding-county{color:var(--blue)}
  .finding-card.gu .finding-county{color:var(--teal)}
  .finding-card.su .finding-county{color:#BA7517}
  .finding-r{font-family:var(--serif);font-size:28px;font-weight:400;margin-bottom:.25rem}
  .finding-card.sj .finding-r{color:var(--blue)}
  .finding-card.gu .finding-r{color:var(--teal)}
  .finding-card.su .finding-r{color:#BA7517}
  .finding-desc{font-size:13px;color:var(--muted);line-height:1.6}
  .finding-p{font-size:12px;color:var(--muted);margin-top:.75rem;border-top:0.5px solid var(--border);padding-top:.75rem}

  .chart-placeholder{background:var(--white);border:0.5px solid var(--border);border-radius:12px;padding:2rem;margin-top:2rem;text-align:center;min-height:260px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.75rem}
  .chart-placeholder svg{opacity:.25}
  .chart-placeholder p{font-size:13px;color:var(--muted)}

  .methods-list{list-style:none;margin-top:1.5rem;display:flex;flex-direction:column;gap:12px}
  .methods-list li{display:flex;gap:12px;align-items:flex-start;font-size:14px;color:var(--muted);line-height:1.6}
  .method-num{min-width:26px;height:26px;border-radius:50%;background:var(--blue-light);color:var(--blue);font-size:12px;font-weight:500;display:flex;align-items:center;justify-content:center;margin-top:1px}

  .team-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-top:2rem}
  .team-card{background:var(--white);border:0.5px solid var(--border);border-radius:12px;padding:1.25rem;display:flex;gap:12px;align-items:center}
  .team-avatar{width:42px;height:42px;border-radius:50%;background:var(--blue-light);color:var(--blue);font-size:14px;font-weight:500;display:flex;align-items:center;justify-content:center;flex-shrink:0}
  .team-name{font-size:14px;font-weight:500;color:var(--text)}
  .team-role{font-size:12px;color:var(--muted)}

  footer{background:var(--white);border-top:1px solid var(--border);padding:2rem;text-align:center;font-size:13px;color:var(--muted)}
  footer a{color:var(--blue);text-decoration:none}

  @media(max-width:640px){
    .nav-links{display:none;position:absolute;top:var(--nav-h);left:0;right:0;background:var(--white);border-bottom:1px solid var(--border);flex-direction:column;padding:1rem 2rem;gap:1rem}
    .nav-links.open{display:flex}
    .nav-toggle{display:flex}
    .hero{padding:3rem 1.5rem 2.5rem}
    .section{padding:3rem 1.5rem}
  }
</style>

